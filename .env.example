# Scuffed Crew — Environment Variables
# Copy to .env and fill in values: cp .env.example .env

# ── SurrealDB ──────────────────────────────────────────────
# Remote DB URL. If unset, server uses an in-memory database.
SURREALDB_URL=ws://localhost:8000
SURREALDB_USER=root
SURREALDB_PASSWORD=          # REQUIRED in production

# ── Discord OAuth ──────────────────────────────────────────
# Leave empty to disable login (safe for local dev).
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# ── Server ─────────────────────────────────────────────────
# Public base URL — used for OAuth redirect URIs and CORS.
REDIRECT_BASE_URL=http://localhost:3000
# Comma-separated origins allowed by CORS. Defaults to REDIRECT_BASE_URL.
ALLOWED_ORIGINS=

# ── Encryption (optional) ─────────────────────────────────
# Base64-encoded 32-byte key for AES-256-GCM field encryption.
# Generate one with: openssl rand -base64 32
ENCRYPTION_KEY=
# Integer key version for rotation support (default: 1).
ENCRYPTION_KEY_VERSION=1

# ── Logging ────────────────────────────────────────────────
RUST_LOG=info
