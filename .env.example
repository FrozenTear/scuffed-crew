# Scuffed Crew — Environment reference (power users)
#
# Novices: prefer ./scripts/install.sh which writes data/secrets.env for you.
# Copy: cp .env.example data/secrets.env && chmod 600 data/secrets.env

# ── SurrealDB ──────────────────────────────────────────────
SURREALDB_USER=root
SURREALDB_PASSWORD=          # REQUIRED — install.sh generates this
SURREALDB_NS=scuffed_crew
SURREALDB_DB=main
# Compose sets SURREALDB_URL=ws://surrealdb:8000 for the app container.

# ── Host publish port (loopback only) ──────────────────────
# install.sh picks a free port and persists it. Do not re-roll on every update.
HOST_PORT=3000

# ── Public URL (OAuth redirects, CORS default) ─────────────
REDIRECT_BASE_URL=http://127.0.0.1:3000
ALLOWED_ORIGINS=

# ── Encryption (Nostr keys etc.) ───────────────────────────
# openssl rand -base64 32
ENCRYPTION_KEY=
ENCRYPTION_KEY_VERSION=1
NOSTR_RELAY_URL=             # e.g. ws://strfry:7777 with --profile relay
NOSTR_CHALLENGE_SECRET=

# ── OAuth (optional) ───────────────────────────────────────
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Cookies / production ───────────────────────────────────
# Release builds already use Secure cookies. Set for HSTS etc.:
# PRODUCTION=1
# SECURE_COOKIES=1

# ── Emergency admin password reset only ────────────────────
# BOOTSTRAP_ADMIN_RESET=1
# BOOTSTRAP_ADMIN_USERNAME=admin
# BOOTSTRAP_ADMIN_PASSWORD=

# ── Logging ────────────────────────────────────────────────
RUST_LOG=info

# ── Matrix notifications (optional) ────────────────────────
# MATRIX_HOMESERVER_URL=
# MATRIX_BOT_ACCESS_TOKEN=
# MATRIX_OFFICER_ROOM_ID=
# MATRIX_GENERAL_ROOM_ID=

# ── Discord webhook notifications (optional) ───────────────
# Fire-and-forget parallel to Matrix. Missing URL = skip that channel.
# DISCORD_WEBHOOK_OFFICERS=https://discord.com/api/webhooks/...
# DISCORD_WEBHOOK_GENERAL=https://discord.com/api/webhooks/...
# Optional kill-switch: unset = enabled when either URL is set; 0/false/off disables.
# DISCORD_WEBHOOKS_ENABLED=1
