# Host Caddy (same pattern as news.scuffedcrew.no).
# 1. DNS: A (or AAAA) for ow.scuffedcrew.no → this VPS
# 2. Point reverse_proxy at HOST_PORT from data/secrets.env (not always 3000)
# 3. Set REDIRECT_BASE_URL=https://ow.scuffedcrew.no in data/secrets.env
# 4. caddy reload / systemctl reload caddy

ow.scuffedcrew.no {
	encode zstd gzip

	# Hashed static assets — cache aggressively
	@hashed path *.wasm *.js *.css
	header @hashed Cache-Control "public, max-age=31536000, immutable"

	# Security headers
	header X-Content-Type-Options "nosniff"
	header X-Frame-Options "DENY"
	header Referrer-Policy "strict-origin-when-cross-origin"

	# Keep compose bound to 127.0.0.1 — only Caddy is public
	reverse_proxy 127.0.0.1:HOST_PORT_HERE
}
